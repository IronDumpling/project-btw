# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit real keys.

# --- Fast model (real-time, low latency) ---
# Used by: Subtext Analyzer, Reply Generator
# Recommended: Groq Llama 3.3 70B
GROQ_API_KEY=your_groq_api_key_here

# --- Capable model (background, deep reasoning) ---
# Used by: Conversation Compressor, Persona Updater, Relationship Updater
# Option A: DeepSeek V3 (cheapest capable option)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Option B: Anthropic Claude Sonnet (best persona analysis quality)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Model selection (change to switch providers) ---
# Fast model name (LiteLLM format)
FAST_MODEL=groq/llama-3.3-70b-versatile
# Capable model name (LiteLLM format)
CAPABLE_MODEL=deepseek/deepseek-chat

# --- Server config ---
BACKEND_PORT=8765
BACKEND_HOST=127.0.0.1
