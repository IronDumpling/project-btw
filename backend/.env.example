# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit real keys.

# --- API Keys ---
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Routing is governance-based, not speed-based ---
# Three layers differ in governance needs:
#   Perception — stateless, vision-capable, auto-triggered
#   Reasoning  — stateless, low-latency, auto-triggered after perception
#   Learning   — stateful (writes Storage), requires explicit user confirm

# --- Perception Layer — screenshot OCR (must support image input) ---
# Options: gpt-4o | claude-3-5-sonnet-20241022 | groq/llama-3.2-11b-vision-preview
PERCEPTION_MODELS=gpt-4o,claude-3-5-sonnet-20241022

# --- Reasoning Layer — Subtext Analyzer, Reply Generator (stateless, low-latency) ---
# Options: groq/llama-3.3-70b-versatile | gpt-4o-mini
REASONING_MODELS=groq/llama-3.3-70b-versatile,gpt-4o-mini

# --- Learning Layer — Persona/Relationship Updaters (stateful writes, quality-first) ---
# Options: gpt-4.1 | gpt-4o-mini | claude-3-5-sonnet-20241022 | deepseek/deepseek-chat
LEARNING_MODELS=gpt-4.1,gpt-4o-mini,claude-3-5-sonnet-20241022,deepseek/deepseek-chat

# --- Server config ---
BACKEND_PORT=8765
BACKEND_HOST=127.0.0.1
