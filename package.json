{
  "name": "btw-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:desktop": "pnpm --filter btw-desktop dev",
    "dev:web": "pnpm --filter btw-web dev",
    "build:desktop": "pnpm --filter btw-desktop build",
    "build:web": "pnpm --filter btw-web build",
    "tauri": "pnpm --filter btw-desktop tauri",
    "dev:mobile": "npm --prefix apps/mobile run start",
    "ios": "npm --prefix apps/mobile run ios",
    "validate:mobile": "npm --prefix apps/mobile run validate"
  },
  "packageManager": "pnpm@9.0.0"
}
